{
  "root": true,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "src/_DEAD/**"
  ],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["@typescript-eslint", "react", "react-hooks"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-empty-object-type": "off",
    "@typescript-eslint/ban-ts-comment": ["warn", { "ts-ignore": "allow-with-description" }],
    "no-prototype-builtins": "off",
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "react/jsx-key": "error",
    "react/no-unescaped-entities": "off",
    "no-console": "warn",
    "no-case-declarations": "off",
    "prefer-const": "warn",
    "no-useless-escape": "off",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          { "name": "antd", "message": "StoryFab 禁止使用 antd，请改用 shadcn/ui (@/components/ui/*)。参考 ADR-002。" },
          { "name": "@ant-design/icons", "message": "StoryFab 禁止使用 @ant-design/*，请改用 lucide-react。参考 ADR-002。" },
          { "name": "@ant-design/colors", "message": "StoryFab 禁止使用 @ant-design/*。参考 ADR-002。" }
        ],
        "patterns": [
          { "group": ["@ant-design/*"], "message": "StoryFab 禁止使用 @ant-design/*。参考 ADR-002。" }
        ]
      }
    ]
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "overrides": [
    {
      "files": ["src/core/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              { "group": ["@/services/*"], "message": "src/core/** 禁止引用 src/services/** (shim 层)，请直接 import @/core/... 参考 ADR-101。" }
            ]
          }
        ]
      }
    }
  ]
}
