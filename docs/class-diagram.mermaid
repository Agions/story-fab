classDiagram
    %% ============================================================
    %% Base Infrastructure Layer
    %% ============================================================

    class BaseService {
        <<abstract>>
        #name: string
        #config: RequestConfig
        +constructor(name: string, config: RequestConfig)
        #executeRequest~T~(requestFn: () => Promise~T~, context?: string) Promise~T~
        #retryRequest~T~(requestFn: () => Promise~T~, retries?: number, delayMs?: number, retryOn?: Function) Promise~T~
        #handleError(error: unknown, context?: string) never
        -normalizeError(error: unknown) ServiceError
    }

    class ServiceError {
        +message: string
        +code?: string
        +statusCode?: number
        +originalError?: Error
        +retryable?: boolean
    }

    class RequestConfig {
        +timeout?: number
        +retries?: number
        +retryDelay?: number
        +retryOn?: (error: ServiceError) => boolean
    }

    BaseService --> ServiceError : throws
    BaseService --> RequestConfig : uses

    %% ============================================================
    %% NEW: Shared Utilities
    %% ============================================================

    class WithFallback {
        <<function>>
        +withFallback~T,F~(fn: () => Promise~T~, fallback: F, context?: string) Promise~T|F~
    }

    class TypeGuards {
        <<function>>
        +isDirectorPlan(value: unknown) boolean
        +isDirectorStatusResponse(value: unknown) boolean
        +isWhisperResult(value: unknown) boolean
        +isTtsBackendArray(value: unknown) boolean
        +isRecordOfStringUnknown(value: unknown) boolean
    }

    %% ============================================================
    %% Services (After Refactoring)
    %% ============================================================

    class VoiceSynthesisService {
        -config: VoiceConfig
        +constructor(config?: Partial~VoiceConfig~)
        +getVoices() VoiceItem[]
        +getChineseVoices() VoiceItem[]
        +listBackends() Promise~TtsBackend[]~
        +checkAvailable() Promise~boolean~
        +preview(text: string) void
        +synthesize(text: string, options?: Partial~VoiceConfig~, onProgress?: Function) Promise~SynthesisResult~
        +synthesizeToBuffer(text: string, options?, onProgress?) Promise~{buffer, duration, contentType}~
        +synthesizeAndSave(text: string, outputPath: string, options?, onProgress?) Promise~SynthesisResult~
        +getConfig() VoiceConfig
        +updateConfig(config: Partial~VoiceConfig~) void
    }

    class AudioVideoSyncService {
        -config: SyncConfig
        +constructor(config?: Partial~SyncConfig~)
        +analyzeSync(videoPath: string, audioPath?: string) Promise~SyncResult~
        +autoSync(videoPath: string, audioPath?: string) Promise~SyncResult~
        +setOffset(offsetMs: number) void
        +getConfig() SyncConfig
        +updateConfig(config: Partial~SyncConfig~) void
        +exportTimeline(segments: TimelineSegment[]) SyncTimeline
        -analyzeTimeline(videoPath: string) Promise~SyncTimeline~
        -fallbackSegments(videoPath: string) Promise~SyncTimeline~
        -detectIssues(timeline: SyncTimeline) Promise~SyncIssue[]
        -calculateOffset(issues: SyncIssue[]) number
        -calculateConfidence(issues: SyncIssue[]) number
        -getStreamIndex(filePath: string, codec: string) Promise~number~
        -getKeyframes(filePath: string) Promise~number[]~
        -getDuration(filePath: string) Promise~number~
        -ffprobeOutput(args: string[]) Promise~string~
    }

    class VisionService {
        +analyzeVideo(videoInfo: VideoInfo, options?: VideoAnalysisOptions) Promise~{scenes, objects, emotions}~
        +detectScenesAdvanced(videoInfo: VideoInfo, options?: VideoAnalysisOptions) Promise~{scenes, objects, emotions}~
        +extractKeyframes(videoInfo: VideoInfo, options?: {maxFrames?: number}) Promise~Keyframe[]~
        +generateAnalysisReport(videoInfo: VideoInfo, scenes: Scene[], objects: ObjectDetection[], emotions: EmotionAnalysis[]) Promise~VideoAnalysis~
        +detectHighlights(videoInfo: VideoInfo, options?: Partial~HighlightOptions~) Promise~HighlightSegment[]~
        -optimizeScenes(scenes: Scene[], objects: ObjectDetection[], emotions: EmotionAnalysis[]) Scene[]
    }

    class ClipWorkflowService {
        -config: ClipConfig
        -_pipeline?: ClipRepurposingPipeline
        +constructor(config?: Partial~ClipConfig~)
        +processVideo(videoInfo: VideoInfo, scriptSegments?: ScriptSegment[]) Promise~ClipResult~
        +processVideoWithPipeline(videoInfo: VideoInfo, analysis?: VideoAnalysis, pipelineOptions?: Partial~RepurposingOptions~, asrSegments?: ASRSegment[]) Promise~ClipResult~
        +exportTimeline(segments: ClipSegment[]) object
        +getExportSettings() ExportSettings
        +optimizeQuality(segments: ClipSegment[]) ClipSegment[]
        +getConfig() ClipConfig
        +updateConfig(config: Partial~ClipConfig~) void
        -analyzeVideo(videoInfo: VideoInfo) Promise~VideoAnalysis~
        -generateClips(analysis: VideoAnalysis, sceneChanges: Array~{time: number}~, silenceSections: Array~{start, end}~, scriptSegments?: ScriptSegment[]) ClipSegment[]
        -runASR(videoInfo: VideoInfo) Promise~ASRSegment[]~
    }

    class AIService {
        -abortControllers: Map~string, AbortController~
        +constructor()
        +generateText(model: AIModel, prompt: string, settings: AIModelSettings) Promise~string~
        +generateScript(model: AIModel, settings: AIModelSettings, params: object) Promise~ScriptData~
        +analyzeVideo(model: AIModel, settings: AIModelSettings, videoInfo: object) Promise~Partial~VideoAnalysis~~
        +optimizeScript(model: AIModel, settings: AIModelSettings, script: string, optimization: string) Promise~string~
        +translateScript(model: AIModel, settings: AIModelSettings, script: string, targetLanguage: string) Promise~string~
        +getRecommendedModels(task: string) AIModel[]
        +getModelInfo(modelId: string) AIModel | null
        +getAllModels() AIModel[]
        +getDomesticModels() AIModel[]
        +cancelRequest(requestId: string) void
        -callAPI(model: AIModel, settings: AIModelSettings, prompt: string) Promise~AIResponse~
    }

    class WhisperService {
        +transcribe(audioPath: string, modelSize?: string, language?: string, onProgress?: Function) Promise~WhisperResult~
        +toSubtitleFormat(result: WhisperResult) {language: string, entries: Array~{id, startTime, endTime, text}~}
    }

    class VideoEffectService {
        -config: EffectConfig
        +constructor(config?: Partial~EffectConfig~)
        +applyPreset(presetId: string) void
        +getPresets(category?: string) EffectPreset[]
        +getCSSFilter() string
        +applyToVideoElement(video: HTMLVideoElement) void
        +getConfig() EffectConfig
        +updateConfig(config: Partial~EffectConfig~) void
        +reset() void
    }

    %% ============================================================
    %% Tauri Layer
    %% ============================================================

    class TauriCommentaryMethods {
        +createSession(sessionId: string, style?: string) Promise~string~
        +getStatus(sessionId: string) Promise~DirectorStatusResponse~
        +startAnalysis(sessionId: string, videoPath: string, subtitles: string, targetDurationSecs?: number) Promise~void~
        +generatePlan(sessionId: string, style?: string, targetDurationSecs?: number) Promise~DirectorPlan~
        +approvePlan(sessionId: string) Promise~string~
        +revisePlan(sessionId: string, modifications: Record~string, unknown~) Promise~DirectorPlan~
        +completeRender(sessionId: string, outputPath: string) Promise~string~
        +destroySession(sessionId: string) Promise~void~
        +generateScript(input: object) Promise~unknown~
        +synthesizeAudio(text: string, voice: string, speed: number, format: string, outputPath?: string) Promise~{audioPath, durationSecs}~
        +estimateTTSDuration(text: string, voice: string, speed: number) Promise~number~
        +listVoices() Promise~Voice[]~
        +runCommentaryPipeline(input: CommentaryPipelineInput) Promise~CommentaryPipelineOutput~
    }

    class CommentarySessionService {
        <<function module>>
        +createCommentarySession(sessionId: string, style?: ScriptStylePreset) Promise~string~
        +getCommentaryStatus(sessionId: string) Promise~DirectorStatusResponse~
        +destroyCommentarySession(sessionId: string) Promise~void~
        +startCommentaryAnalysis(sessionId: string, videoPath: string, subtitles: string, targetDurationSecs?: number) Promise~void~
        +generateCommentaryPlan(sessionId: string, style?: ScriptStylePreset, targetDurationSecs?: number) Promise~DirectorPlan~
        +approveCommentaryPlan(sessionId: string) Promise~string~
        +reviseCommentaryPlan(sessionId: string, modifications: PlanModifications) Promise~DirectorPlan~
        +completeCommentaryRender(sessionId: string, outputPath: string) Promise~string~
    }

    class TauriInvoke {
        <<function>>
        +invoke~C~(command: C, args?: Record~string, unknown~, options?: BridgeOptions) Promise~TauriCommandOutput~C~~
        +runCommentaryPipeline(input: CommentaryPipelineInput) Promise~CommentaryPipelineOutput~
        -executeWithRetry~C~(command: C, args: Record~string, unknown~, retries: number, signal?: AbortSignal) Promise~TauriCommandOutput~C~~
    }

    %% ============================================================
    %% Pipeline Layer
    %% ============================================================

    class CompositeCommentaryPipeline {
        <<function module>>
        +createCommentaryPipeline() ChainPipeline~Start, End~
        +runCommentaryPipeline(state: CommentaryPipelineState, options?: StepOptions) Promise~CommentaryPipelineResult~
    }

    class ClipRepurposingPipeline {
        +run(videoInfo: VideoInfo, analysis: VideoAnalysis, options?: RepurposingOptions, asrSegments?: ASRSegment[]) Promise~RepurposingResult~
    }

    %% ============================================================
    %% Relationships
    %% ============================================================

    BaseService <|-- VoiceSynthesisService : extends
    BaseService <|-- AIService : extends (existing)
    BaseService <|-- ASRService : extends (existing, not modified)
    BaseService <|-- SubtitleService : extends (existing, not modified)
    BaseService <|-- ExportService : extends (existing, not modified)

    WithFallback ..> AudioVideoSyncService : uses in analyzeTimeline()
    WithFallback ..> VisionService : uses in extractKeyframes() & detectHighlights()
    WithFallback ..> ClipWorkflowService : uses in runASR()
    WithFallback ..> VoiceSynthesisService : uses in listBackends() & checkAvailable()

    TypeGuards ..> TauriCommentaryMethods : isDirectorPlan()
    TypeGuards ..> CommentarySessionService : isDirectorPlan()
    TypeGuards ..> WhisperService : isWhisperResult()
    TypeGuards ..> VoiceSynthesisService : isTtsBackendArray()

    TauriCommentaryMethods --> TauriInvoke : calls invoke~C~()
    CommentarySessionService --> TauriCommentaryMethods : delegates to tauri.*
    WhisperService --> TauriInvoke : calls tauri.transcribeAudio()
    VoiceSynthesisService --> TauriInvoke : calls tauri.synthesizeSpeech()

    ClipWorkflowService --> ClipRepurposingPipeline : delegates heavy work
    ClipWorkflowService --> VisionService : analyzeVideo()
    ClipWorkflowService --> AIService : (indirect via pipeline)

    CompositeCommentaryPipeline --> CommentarySessionService : delegates to step logic

    VideoEffectService : NO CHANGE — synchronous config only

    note for VideoEffectService "100% synchronous<br/>in-memory config manipulation.<br/>No BaseService value."
