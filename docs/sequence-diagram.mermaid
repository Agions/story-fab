sequenceDiagram
    %% ============================================================
    %% VoiceSynthesisService.synthesize() — After BaseService adoption
    %% ============================================================
    participant Caller
    participant VSS as VoiceSynthesisService<br/>(extends BaseService)
    participant BS as BaseService.executeRequest()
    participant Tauri as tauri facade
    participant Logger

    Caller->>VSS: synthesize(text, options, onProgress)
    VSS->>Caller: onProgress({ stage: 'queued', progress: 10 })
    VSS->>Caller: onProgress({ stage: 'synthesizing', progress: 30 })
    VSS->>BS: executeRequest(fn, '语音合成')
    BS->>Tauri: tauri.synthesizeSpeech(input)
    Tauri-->>BS: outputPath (string)
    BS-->>VSS: outputPath
    VSS->>Caller: onProgress({ stage: 'encoding', progress: 90 })
    VSS->>Caller: onProgress({ stage: 'done', progress: 100 })
    VSS->>Logger: logger.info('Synthesized:', {...})
    VSS-->>Caller: SynthesisResult

    Note over BS: On error:<br/>normalizeError() → logger.error() → throw ServiceError<br/>NO double-logging!

    %% ============================================================
    %% VisionService.extractKeyframes() — withFallback pattern
    %% ============================================================

    participant VS as VisionService
    participant WF as withFallback()

    Caller->>VS: extractKeyframes(videoInfo, { maxFrames: 20 })
    VS->>WF: withFallback(detectAndSample, fallbackFn, '关键帧提取')
    WF->>VS: detectAndSample()
    VS->>VS: detectScenesAdvanced(...)

    alt Scene detection succeeds
        VS-->>WF: keyframe array (sampled from scenes)
        WF-->>VS: keyframe array
        VS-->>Caller: keyframe array
    else Scene detection fails
        VS-->>WF: throw Error
        WF->>Logger: logger.warn('关键帧提取 失败，使用降级方案:', error)
        WF->>VS: fallbackFn()
        VS-->>WF: time-based uniform keyframes
        WF-->>VS: fallback keyframe array
        VS-->>Caller: fallback keyframe array
    end

    %% ============================================================
    %% AudioVideoSyncService.analyzeTimeline() — withFallback
    %% ============================================================

    participant AVS as AudioVideoSyncService

    Caller->>AVS: analyzeTimeline(videoPath)
    AVS->>WF: withFallback(ffprobeLogic, fallbackSegments(videoPath), 'FFprobe分析')
    WF->>AVS: ffprobeLogic()

    alt FFprobe succeeds
        AVS->>AVS: getStreamIndex() → getKeyframes() → build segments
        AVS-->>WF: { videoSegments, issues: [] }
    else FFprobe fails
        AVS-->>WF: throw Error
        WF->>Logger: logger.warn('FFprobe 分析失败，使用默认分段:', error)
        WF-->>AVS: fallbackSegments result
    end
    AVS-->>Caller: SyncTimeline

    %% ============================================================
    %% Tauri commentary.generatePlan() — Type guard pattern
    %% ============================================================

    participant CM as commentary methods
    participant Invoke as invoke~C~()
    participant TG as isDirectorPlan()
    participant Rust as Rust Backend

    Caller->>CM: generatePlan(sessionId, style, targetDurationSecs)
    CM->>Invoke: invoke('generate_director_plan', {...})
    Invoke->>Rust: Tauri IPC
    Rust-->>Invoke: Record~string, unknown~
    Invoke-->>CM: Record~string, unknown~
    CM->>TG: isDirectorPlan(raw)

    alt Valid DirectorPlan shape
        TG-->>CM: true → narrowed to DirectorPlan
        CM-->>Caller: DirectorPlan
    else Invalid shape
        TG-->>CM: false
        CM->>CM: throw Error('Invalid DirectorPlan response')
        CM-->>Caller: throws
    end

    %% ============================================================
    %% WhisperService.transcribe() — Type guard for Rust response
    %% ============================================================

    participant WS as WhisperService
    participant IW as isWhisperResult()

    Caller->>WS: transcribe(audioPath, modelSize, language, onProgress)
    WS->>Tauri: tauri.transcribeAudio({ audioPath, modelSize, language })
    Tauri->>Rust: Tauri IPC
    Rust-->>Tauri: raw response (WhisperResult-shaped)
    Tauri-->>WS: raw response
    WS->>IW: isWhisperResult(raw)

    alt Valid WhisperResult
        IW-->>WS: true → narrowed to WhisperResult
        WS->>Logger: logger.info('转录完成:', {...})
        WS-->>Caller: WhisperResult
    else Invalid shape
        IW-->>WS: false
        WS->>WS: throw Error('转录返回数据格式异常')
        WS-->>Caller: throws
    end

    %% ============================================================
    %% ClipWorkflowService.runASR() — withFallback pattern
    %% ============================================================

    participant CWS as ClipWorkflowService
    participant ASR as asrService

    Caller->>CWS: runASR(videoInfo)
    CWS->>WF: withFallback(() => asrService.recognizeSpeech(videoInfo), [], 'ASR识别')
    WF->>ASR: recognizeSpeech(videoInfo)

    alt ASR succeeds
        ASR-->>WF: ASRResult with segments
        WF-->>CWS: segments array
    else ASR fails
        ASR-->>WF: throw Error
        WF->>Logger: logger.warn('ASR 识别 失败，使用降级方案:', error)
        WF-->>CWS: [] (empty array)
    end
    CWS-->>Caller: ASRSegment[]
