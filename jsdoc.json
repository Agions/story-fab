{
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "source": {
    "include": ["src", "src-tauri/src"],
    "includePattern": ".+\\.(j|t)sx?$",
    "excludePattern": "(node_modules/|docs/|dist/|src-tauri/target/)",
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx"
    ]
  },
  "plugins": [
    "node_modules/jsdoc-tsimport-plugin"
  ],
  "templates": {
    "default": {
      "outputSourceFiles": true,
      "useLongnameInNav": true
    }
  },
  "opts": {
    "destination": "docs/jsdoc",
    "recurse": true,
    "verbose": true
  }
}
