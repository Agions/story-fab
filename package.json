{
  "name": "cutdeck",
  "private": true,
  "version": "1.7.0",
  "description": "开源AI视频剪辑工具。长视频自动拆条为爆款短片段 · 9:16/1:1/16:9多格式导出 · 本地Whisper字幕 · Rust渲染管线 · 无需上传",
  "author": "Agions <agions@qq.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:budget": "node scripts/check-bundle-budget.mjs",
    "build:ci": "npm run build && npm run build:budget",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "tauri": "tauri",
    "tauri:build:dmg": "bash scripts/build-dmg.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 250",
    "lint:core": "node scripts/lint-core.mjs",
    "lint:legacy": "eslint src --ext .ts,.tsx --rule '@typescript-eslint/ban-ts-comment: off'",
    "lint:all": "npm run lint:core && npm run lint:legacy",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,less}\"",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "antd": "^5.29.3",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "i18next": "^25.8.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.30.3",
    "uuid": "^11.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vuepress/theme-default": "^1.9.10",
    "babel-plugin-import": "^1.13.8",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "docsify-cli": "^4.4.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "less": "^4.2.2",
    "terser": "^5.46.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}
