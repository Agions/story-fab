{
  "name": "story-fab",
  "productName": "StoryFab",
  "private": true,
  "version": "2.2.0",
  "description": "开源 AI 影视解说创作工坊 (Tauri 2 + Rust)。长视频 → AI 拆条 + 多 Agent 智能解说 + 本地 Whisper 字幕 + 配音合成，9:16/1:1/16:9 多格式导出，100% 本地处理零上传。",
  "author": "Agions <agions@qq.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:budget": "node scripts/check-bundle-budget.mjs",
    "build:ci": "npm run build && npm run build:budget",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "tauri": "tauri",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 50",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,less}\"",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:run": "npx vitest run",
    "docs:build": "cp CHANGELOG.md docs/CHANGELOG.md && npx vitepress build docs",
    "docs:preview": "npx vitepress preview docs",
    "docs:jsdoc": "jsdoc -c jsdoc.json",
    "test:ci": "vitest run --coverage",
    "bench": "vitest bench --run src/__bench__",
    "verify:antd": "node scripts/check-antd.mjs",
    "verify:naming": "node scripts/check-naming.mjs",
    "verify:all": "npm run verify:antd && npm run verify:naming"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "less": "^4.2.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}
